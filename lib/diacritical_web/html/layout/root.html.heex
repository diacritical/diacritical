<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csp-token" content={sign(assigns[:nonce])} />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content={assigns[:page_description] || "Here be dragons."}
    />
    <.live_title><%= assigns[:page_title] || "Diacritical" %></.live_title>
    <link
      nonce={assigns[:nonce]}
      href={~p"/asset/vendor/inter/inter.css"}
      rel="stylesheet"
      phx-track-static
    />
    <link
      nonce={assigns[:nonce]}
      href={~p"/asset/css/app.css"}
      rel="stylesheet"
      phx-track-static
    />
  </head>
  <body>
    <%= @inner_content %>
    <script
      nonce={assigns[:nonce]}
      src={~p"/asset/js/app.js"}
      defer
      phx-track-static
    >
    </script>
  </body>
</html>
